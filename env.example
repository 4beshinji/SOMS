# System Configuration
LOG_LEVEL=INFO
TZ=Asia/Tokyo
SOMS_ENV=development

# MQTT Broker
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=soms
MQTT_PASS=soms_dev_mqtt

# LLM Configuration
# Options:
# - http://mock-llm:8000/v1              (Testing with mock LLM)
# - http://ollama:11434/v1               (Docker internal Ollama)
# - http://host.docker.internal:11434/v1 (Host Ollama via Docker bridge)
# - https://api.openai.com/v1            (Cloud API)
LLM_API_URL=http://mock-llm:8000/v1
LLM_MODEL=qwen3.5:9b
# OPENAI_API_KEY=sk-... (If using Cloud API)

# PostgreSQL
POSTGRES_USER=soms
POSTGRES_PASSWORD=soms_dev_password
DATABASE_URL=postgresql+asyncpg://soms:soms_dev_password@postgres:5432/soms

# MQTT Bind Address (optional, restrict MQTT listener to specific interface)
# MQTT_BIND_ADDR=0.0.0.0

# Perception
RTSP_URL=rtsp://virtual-camera:8554/live
# RTSP_URL=rtsp://192.168.1.50:8554/cam (Real Camera)

# GPU Backend
#
# AMD GPU (ROCm) — default; uses infra/docker-compose.yml as-is.
#   Override GFX version for compatibility (e.g. 12.0.1 for RDNA4):
# HSA_OVERRIDE_GFX_VERSION=12.0.1
#
# NVIDIA GPU (CUDA) — start with the override file:
#   docker compose -f infra/docker-compose.yml \
#                  -f infra/docker-compose.nvidia.yml up -d --build
#   Requires nvidia-container-toolkit on the host.
# NVIDIA_GPU_COUNT=1

# SwitchBot Cloud Bridge
# SWITCHBOT_TOKEN=your_switchbot_open_token
# SWITCHBOT_SECRET=your_switchbot_secret_key

# Zigbee2MQTT
# SOMS_PORT_Z2M_FRONTEND=8008

# Auth Service (JWT + OAuth)
JWT_SECRET=soms_dev_jwt_secret_change_me
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AUTH_BASE_URL=https://localhost:8443/api/auth
# FRONTEND_URL=https://localhost:8443

# Inter-Service Authentication
# Generate a strong random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_TOKEN=

# VLM (Vision Language Model)
# VLM_ENABLED=false
# VLM_MODEL=qwen3-vl:8b
# VLM_API_URL=http://localhost:11434

# TTS Backend ("voicepeak" or "voicevox")
TTS_BACKEND=voicepeak
# VOICEPEAK bridge server URL (runs on host, Docker voice-service calls this)
VOICEPEAK_BRIDGE_URL=http://host.docker.internal:18100
# VOICEPEAK narrator name (run voicepeak --list-narrator to see available narrators)
VOICEPEAK_NARRATOR=Otomachi Una

# Speech-to-Text (STT)
STT_MODEL=kotoba-tech/kotoba-whisper-v2.0-faster

# Chat (Brain chat server)
BRAIN_CHAT_PORT=8080
CHAT_CLEANUP_MODEL=qwen3.5:4b
CHAT_MAX_RESPONSE_CHARS=80

# Federation
# SOMS_REGION_ID=local
